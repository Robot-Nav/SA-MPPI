<?xml version="1.0"?>
<launch>
  <!-- 启动 Gazebo 空世界 -->
  <arg name="gui" default="true"/>

  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="use_sim_time" value="true"/>
    <arg name="debug" value="false"/>
    <arg name="gui" value="$(arg gui)" />
    <!-- 不指定 world_name，自动使用默认的空世界 -->
  </include>

  <!-- 加载 Pioneer 机器人模型（来自 pioneer_utils） -->
  <include file="$(find pioneer_utils)/gazebo/launch/base.launch.xml">
  </include>

  <!-- 发布机器人状态 -->
  <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher">
    <param name="publish_frequency" type="double" value="30.0" />
  </node>

  <!-- 静态地图服务器 -->
  <arg name="map_file" default="/home/shaoyu/robot_ws/map/PM.yaml"/>
  <node pkg="map_server" type="map_server" name="map_server" args="$(arg map_file)"/>

  <!-- 静态变换发布器：map -> odom（代替 AMCL） -->
  <node pkg="tf2_ros" type="static_transform_publisher" name="map_to_odom" 
        args="0 0 0 0 0 0 map odom"/>


  <!-- move_base 导航节点（teb_local_planner/TebLocalPlannerROS/dwa_local_planner/DWAPlannerROS） -->
  <arg name="cmd_vel_topic" default="/cmd_vel" />
  <arg name="odom_topic" default="odom" />
  <arg name="move_forward_only" default="false"/>

  <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
    <param name="base_local_planner" value="dwa_local_planner/DWAPlannerROS" />
    
    <!-- 代价地图通用参数（分别加载到全局和局部命名空间） -->
    <rosparam file="$(find pioneer_navigation)/navigation/costmap_common_params.yaml" command="load" ns="global_costmap" />
    <rosparam file="$(find pioneer_navigation)/navigation/costmap_common_params.yaml" command="load" ns="local_costmap" />
    
    <!-- 局部和全局代价地图专用参数 -->
    <rosparam file="$(find pioneer_navigation)/navigation/local_costmap_params.yaml" command="load" />
    <rosparam file="$(find pioneer_navigation)/navigation/global_costmap_params.yaml" command="load" />
    
    <!-- move_base 自身参数 -->
    <rosparam file="$(find pioneer_navigation)/navigation/move_base_params.yaml" command="load" />
    
    <!-- 局部规划器参数（base_local_planner_ackermann_params/base_local_planner_default_params） -->
    <rosparam file="$(find pioneer_navigation)/navigation/base_local_planner_default_params.yaml" command="load" />
    
    <!-- 话题重映射 -->
    <remap from="cmd_vel" to="$(arg cmd_vel_topic)"/>
    <remap from="odom" to="$(arg odom_topic)"/>
    
    <!-- 若仅向前移动，设置最小速度为0 -->
    <!--param name="DWAPlannerROS/min_vel_x" value="0.0" if="$(arg move_forward_only)" /-->
  </node>
</launch>

